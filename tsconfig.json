{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@kirigami/*": ["kirigami/*"]
    }
  },
  "include": [
    "src/**/*",
    "kirigami/**/*",
    "scripts/**/*",
    "tests/**/*",
    "vite.config.ts",
    "vitest.config.ts"
  ]
}

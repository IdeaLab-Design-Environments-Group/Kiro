solid tetrahedron
  facet normal 0.577350 0.577350 -0.577350
    outer loop
      vertex 50 50 50
      vertex 50 -50 -50
      vertex -50 50 -50
    endloop
  endfacet
  facet normal 0.577350 -0.577350 0.577350
    outer loop
      vertex 50 50 50
      vertex -50 -50 50
      vertex 50 -50 -50
    endloop
  endfacet
  facet normal -0.577350 0.577350 0.577350
    outer loop
      vertex 50 50 50
      vertex -50 50 -50
      vertex -50 -50 50
    endloop
  endfacet
  facet normal -0.577350 -0.577350 -0.577350
    outer loop
      vertex 50 -50 -50
      vertex -50 -50 50
      vertex -50 50 -50
    endloop
  endfacet
endsolid tetrahedron

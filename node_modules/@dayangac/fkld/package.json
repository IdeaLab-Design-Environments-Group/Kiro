{
  "name": "@dayangac/fkld",
  "version": "0.2.0",
  "description": "FKLD (Flexible Kirigami List Datastructure) — a JSON file format extending FOLD for kirigami architecture design. Format core: spec/KEYS registry, cut subtypes, edge-molecule params, IO.",
  "type": "module",
  "main": "lib/index.js",
  "module": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./spec": {
      "types": "./lib/spec.d.ts",
      "default": "./lib/spec.js"
    },
    "./cut-types": {
      "types": "./lib/cut-types.d.ts",
      "default": "./lib/cut-types.js"
    },
    "./molecule": {
      "types": "./lib/molecule.d.ts",
      "default": "./lib/molecule.js"
    },
    "./io": {
      "types": "./lib/io.d.ts",
      "default": "./lib/io.js"
    }
  },
  "files": [
    "lib/",
    "src/",
    "FKLD-SPEC.md",
    "LICENSE",
    "LICENSE-FOLD",
    "README.md"
  ],
  "scripts": {
    "coffee": "coffee --no-header --bare -o lib -c src",
    "build": "npm run coffee && cp src/*.d.ts lib/",
    "test": "node test/smoke.mjs",
    "prepublishOnly": "npm run build && npm test",
    "clean": "rm -rf lib"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/idealab-design-environments-group/FKLD.git"
  },
  "homepage": "https://github.com/idealab-design-environments-group/FKLD#readme",
  "keywords": [
    "kirigami",
    "origami",
    "fold",
    "crease",
    "pattern",
    "architecture",
    "fabrication",
    "computational-design"
  ],
  "author": "Emre Dayangac",
  "license": "MIT",
  "devDependencies": {
    "coffeescript": "^2.7.0"
  }
}

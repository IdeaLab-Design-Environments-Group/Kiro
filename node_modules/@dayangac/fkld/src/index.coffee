# FKLD — Flexible Kirigami List Datastructure (format core).
#
# 0.2.0 re-baselines the published library onto the design the Kirigamizer
# app actually uses: a JSON format that is a strict superset of FOLD 1.2,
# with kirigami/architecture metadata under the reserved `fkld:` namespace.
#
# The barrel re-exports the four format modules as a flat named surface so
# consumers can `import { KEYS, validateEdgeCutTypes } from "@dayangac/fkld"`,
# or reach a single module via its subpath (e.g. "@dayangac/fkld/spec").
#
#   spec       — namespace + nested KEYS registry (single source of truth)
#   cut-types  — the seven "C"-edge subtypes + validateEdgeCutTypes
#   molecule   — per-edge Tachi molecule params + validateMoleculeArrays
#   io         — parse/serialize FKLD JSON text
#
# (App glue such as the AKDE FoldNet -> FKLD bridge is intentionally NOT in
# this package; it is coupled to app-internal types and lives in the app.)

export * from "./spec.js"
export * from "./cut-types.js"
export * from "./molecule.js"
export * from "./io.js"
